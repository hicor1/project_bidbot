*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/

# 환경변수 / 시크릿
.env
.env.*
!.env.example
*.ini
credentials.json
token.json
*.key
*.pem

# 로그 / 출력물
로그/
logs/
*.log
*.xlsx
*.xlsm
*.csv
