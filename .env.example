# project_bidbot 환경변수 샘플
#
# 사용법:
#   1. 이 파일을 같은 위치에 `.env` 로 복사
#   2. 아래 값들을 실제 값으로 채움
#   3. .env 는 .gitignore 차단됨 (커밋되지 않음)

# ── KREAM 이메일 로그인 ──
KREAM_EMAIL=your_email@example.com
KREAM_PW=your_password

# ── 구글시트 ──
# 서비스 계정 JSON 키 경로. 절대 커밋 금지.
# 권장 위치: 프로젝트 밖 (예: C:\Users\hicor\.bidbot\sheets-key.json)
GOOGLE_CREDENTIALS_PATH=C:\path\to\service-account.json

# 스프레드시트 ID. URL 의 /d/ 뒤 긴 문자열.
GOOGLE_SHEET_ID=

# 탭 이름. 생략 시 '상품마스터'
GOOGLE_SHEET_WORKSHEET=상품마스터

# ── (추후 추가) ──
# DISCORD_WEBHOOK_URL=...
# TELEGRAM_BOT_TOKEN=...
