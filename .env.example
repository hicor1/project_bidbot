# project_bidbot 환경변수 샘플
#
# 사용법:
#   1. 이 파일을 같은 위치에 `.env` 로 복사
#   2. 아래 값들을 실제 값으로 채움
#   3. .env 는 .gitignore 차단됨 (커밋되지 않음)
#
# 로드 위치:
#   test/sell_asks_test/_common.py 가 프로젝트 루트 `.env` 를 자동 로드.
#   python-dotenv 있으면 그걸 사용, 없으면 자체 파서.

# KREAM 이메일 로그인
KREAM_EMAIL=your_email@example.com
KREAM_PW=your_password

# (추후 추가)
# GOOGLE_CREDENTIALS_PATH=./credentials.json
# GOOGLE_SHEET_ID=...
# DISCORD_WEBHOOK_URL=...
# TELEGRAM_BOT_TOKEN=...
