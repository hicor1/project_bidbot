# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/

# 환경변수 / 시크릿
.env
.env.*
!.env.example
*.ini
credentials.json
token.json
*.key
*.pem
# 구글 서비스 계정 JSON — 형식/위치 상관없이 전부 차단
*service-account*.json
*service_account*.json
project-bitbot-*.json
# secret/ 이라는 이름 붙은 폴더는 어디에 있든 통째 차단
**/secret/
**/secrets/
**/.secret/

# 로그 / 출력물
로그/
logs/
*.log
*.xlsx
*.xlsm
*.csv
# 예외: docs/ 하위 템플릿·샘플은 공유 대상
!docs/*.xlsx
!docs/*.csv

# IDE
.vscode/
.idea/
.spyproject/
*.code-workspace

# OS
.DS_Store
Thumbs.db

# PyInstaller (KREAM_BASE 잔재 방지)
*.spec
dist/
# PyInstaller 출력물은 무시하되, build/pyinstaller/ build/docker/ 같은 설정 폴더는 허용
build/**/build/
build/**/dist/
